ignore-build-scripts=false
# pnpm 11+ supply-chain policy: by default rejects packages published in the
# last 24h to give time for malicious releases to be caught. Set to 0 because
# we trust the upstream deps we pin (oxlint/oxfmt ship platform bindings
# that get published in batches and would otherwise block deploys for a day
# after every release).
minimum-release-age=0
