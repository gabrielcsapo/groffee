{
  "name": "groffee",
  "version": "0.0.1",
  "private": true,
  "description": "The best way to deal with git is with a little bit of coffee",
  "keywords": [
    "git",
    "server",
    "ui"
  ],
  "license": "Apache-2.0",
  "author": "Gabriel J. Csapo <gabecsapo@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gabrielcsapo/groffee.git"
  },
  "type": "module",
  "scripts": {
    "start": "pnpm run build && pnpm --filter @groffee/web start",
    "dev": "pnpm --filter @groffee/web dev",
    "dev:docs": "pnpm --filter @groffee/docs dev",
    "build": "pnpm -r build",
    "build:docs": "pnpm --filter @groffee/docs build",
    "db:generate": "pnpm --filter @groffee/db generate",
    "db:migrate": "pnpm --filter @groffee/db migrate",
    "typecheck": "pnpm -r typecheck",
    "lint": "oxlint .",
    "fmt": "oxfmt --write .",
    "seed": "pnpm --filter @groffee/web seed",
    "make-admin": "pnpm --filter @groffee/web make-admin",
    "admin": "pnpm --filter @groffee/web admin",
    "test": "playwright test",
    "prepare": "husky"
  },
  "dependencies": {
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "husky": "^9.1.7",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@11.1.3"
}
