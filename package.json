{
  "name": "groffee",
  "version": "0.0.1",
  "private": true,
  "description": "The best way to deal with git is with a little bit of coffee",
  "type": "module",
  "scripts": {
    "start": "pnpm --filter @groffee/web start",
    "dev": "pnpm --filter @groffee/web dev",
    "build": "pnpm -r build",
    "db:generate": "pnpm --filter @groffee/db generate",
    "db:migrate": "pnpm --filter @groffee/db migrate",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "fmt": "pnpm -r fmt",
    "seed": "pnpm --filter @groffee/web seed",
    "make-admin": "pnpm --filter @groffee/web make-admin",
    "test": "pnpm --filter @groffee/web test:e2e"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gabrielcsapo/groffee.git"
  },
  "keywords": [
    "git",
    "server",
    "ui"
  ],
  "author": "Gabriel J. Csapo <gabecsapo@gmail.com>",
  "license": "Apache-2.0",
  "devDependencies": {
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@node-rs/argon2",
      "better-sqlite3",
      "cpu-features",
      "esbuild",
      "ssh2"
    ]
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  }
}
